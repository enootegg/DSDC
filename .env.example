# Crowdin API token
# Отримати на: https://crowdin.com/settings#api-key
CROWDIN_TOKEN=your_crowdin_api_token_here

# Cloudflare R2 (для скачування Sources при збірці)
# Account ID: Cloudflare dashboard → правий бічний блок
R2_ACCOUNT_ID=your_cloudflare_account_id
# Access Key ID та Secret: R2 → Manage R2 API Tokens → Create API Token
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
